{
  "name": "feature-maps",
  "version": "0.1.0",
  "description": "Map source code to feature requirements with DevTools-compatible source maps",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fmap": "node packages/core/dist/cli.js",
    "fmap:scan": "node packages/core/dist/cli.js scan",
    "release": "tsx scripts/release.ts",
    "publish-all": "tsx scripts/publish.ts"
  },
  "devDependencies": {
    "tsx": "^4.22.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sergeychernyshev/feature-maps.git"
  },
  "bugs": {
    "url": "https://github.com/sergeychernyshev/feature-maps/issues"
  },
  "homepage": "https://github.com/sergeychernyshev/feature-maps#readme"
}
