{
  "name": "feature-maps",
  "version": "0.1.0",
  "description": "Map source code to feature requirements with DevTools-compatible source maps",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "fmap": "node packages/core/dist/cli.js",
    "publish-all": "scripts/publish.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
